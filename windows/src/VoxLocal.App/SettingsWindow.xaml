<Window x:Class="VoxLocal.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="560" Height="520" ResizeMode="NoResize">
    <TabControl Margin="8">
        <TabItem x:Name="GeneralTab">
            <StackPanel Margin="16">
                <GroupBox x:Name="HotkeyGroup">
                    <StackPanel Margin="8">
                        <DockPanel>
                            <TextBlock x:Name="HotkeyLabel" VerticalAlignment="Center"/>
                            <Button x:Name="HotkeyButton" HorizontalAlignment="Right" MinWidth="140" Click="HotkeyButton_Click"/>
                        </DockPanel>
                        <TextBlock x:Name="HotkeyErrorText" Foreground="Red" Visibility="Collapsed" TextWrapping="Wrap"/>
                        <TextBlock x:Name="ModeLabel" Margin="0,10,0,2"/>
                        <RadioButton x:Name="ModeHold" GroupName="HotkeyMode" Checked="Mode_Checked"/>
                        <RadioButton x:Name="ModeToggle" GroupName="HotkeyMode" Checked="Mode_Checked"/>
                    </StackPanel>
                </GroupBox>
                <GroupBox x:Name="AudioGroup" Margin="0,10,0,0">
                    <DockPanel Margin="8">
                        <TextBlock x:Name="MicLabel" VerticalAlignment="Center"/>
                        <ComboBox x:Name="MicCombo" MinWidth="260" HorizontalAlignment="Right"
                                  SelectionChanged="MicCombo_SelectionChanged"/>
                    </DockPanel>
                </GroupBox>
                <GroupBox x:Name="InsertionGroup" Margin="0,10,0,0">
                    <StackPanel Margin="8">
                        <RadioButton x:Name="InsertAuto" GroupName="Insertion" Checked="Insertion_Checked"/>
                        <RadioButton x:Name="InsertClipboard" GroupName="Insertion" Checked="Insertion_Checked"/>
                    </StackPanel>
                </GroupBox>
                <GroupBox x:Name="AppGroup" Margin="0,10,0,0">
                    <StackPanel Margin="8">
                        <CheckBox x:Name="LaunchAtLoginBox" Click="LaunchAtLoginBox_Click"/>
                        <DockPanel Margin="0,8,0,0">
                            <TextBlock x:Name="UiLangLabel" VerticalAlignment="Center"/>
                            <ComboBox x:Name="UiLangCombo" MinWidth="180" HorizontalAlignment="Right"
                                      SelectionChanged="UiLangCombo_SelectionChanged"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </TabItem>
        <TabItem x:Name="TranscriptionTab">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">
                    <GroupBox x:Name="InstalledGroup">
                        <StackPanel Margin="8">
                            <TextBlock x:Name="NoModelsText" Foreground="Gray" Visibility="Collapsed"/>
                            <ComboBox x:Name="ModelCombo" SelectionChanged="ModelCombo_SelectionChanged"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox x:Name="DownloadGroup" Margin="0,10,0,0">
                        <StackPanel Margin="8">
                            <StackPanel x:Name="DownloadList"/>
                            <TextBlock x:Name="DownloadErrorText" Foreground="Red" Visibility="Collapsed" TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox x:Name="RecognitionGroup" Margin="0,10,0,0">
                        <StackPanel Margin="8">
                            <DockPanel>
                                <TextBlock x:Name="SpokenLabel" VerticalAlignment="Center"/>
                                <ComboBox x:Name="SpokenCombo" MinWidth="200" HorizontalAlignment="Right"
                                          SelectionChanged="SpokenCombo_SelectionChanged"/>
                            </DockPanel>
                            <DockPanel Margin="0,8,0,0">
                                <TextBlock x:Name="ThreadsLabel" VerticalAlignment="Center"/>
                                <Slider x:Name="ThreadsSlider" Minimum="1" Maximum="16" TickFrequency="1"
                                        IsSnapToTickEnabled="True" MinWidth="200" HorizontalAlignment="Right"
                                        ValueChanged="ThreadsSlider_ValueChanged"/>
                            </DockPanel>
                            <CheckBox x:Name="ArtifactsBox" Margin="0,8,0,0" Click="ArtifactsBox_Click"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem x:Name="RefinementTab">
            <StackPanel Margin="16">
                <CheckBox x:Name="RefineEnabledBox" Click="RefineEnabledBox_Click"/>
                <TextBlock x:Name="RefineHintText" Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,10"/>
                <GroupBox x:Name="OllamaGroup">
                    <StackPanel x:Name="OllamaPanel" Margin="8">
                        <TextBox x:Name="EndpointBox" TextChanged="EndpointBox_TextChanged"/>
                        <DockPanel Margin="0,8,0,0">
                            <ComboBox x:Name="OllamaModelsCombo" DockPanel.Dock="Right" MinWidth="48"
                                      Visibility="Collapsed" SelectionChanged="OllamaModelsCombo_SelectionChanged"/>
                            <TextBox x:Name="OllamaModelBox" TextChanged="OllamaModelBox_TextChanged"/>
                        </DockPanel>
                        <DockPanel Margin="0,8,0,0">
                            <Button x:Name="CheckButton" Click="CheckButton_Click" MinWidth="120"/>
                            <TextBlock x:Name="AvailabilityText" Foreground="Gray" Margin="8,0,0,0"
                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </DockPanel>
                        <DockPanel Margin="0,8,0,0">
                            <TextBlock x:Name="TimeoutLabel" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TimeoutValueText" DockPanel.Dock="Right" VerticalAlignment="Center"/>
                            <Slider x:Name="TimeoutSlider" Minimum="5" Maximum="60" TickFrequency="5"
                                    IsSnapToTickEnabled="True" Margin="8,0" ValueChanged="TimeoutSlider_ValueChanged"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>
                <GroupBox x:Name="PresetGroup" Margin="0,10,0,0">
                    <StackPanel x:Name="PresetPanel" Margin="8">
                        <ComboBox x:Name="PresetCombo" SelectionChanged="PresetCombo_SelectionChanged"/>
                        <TextBox x:Name="CustomInstructionBox" Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                                 Margin="0,8,0,0" Visibility="Collapsed" TextChanged="CustomInstructionBox_TextChanged"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </TabItem>
        <TabItem x:Name="PrivacyTab">
            <StackPanel Margin="16">
                <GroupBox x:Name="PrivacyGroup">
                    <StackPanel x:Name="PrivacyPoints" Margin="8"/>
                </GroupBox>
                <GroupBox x:Name="DiagnosticsGroup" Margin="0,10,0,0">
                    <StackPanel Margin="8">
                        <DockPanel>
                            <TextBlock x:Name="LogLevelLabel" VerticalAlignment="Center"/>
                            <ComboBox x:Name="LogLevelCombo" MinWidth="160" HorizontalAlignment="Right"
                                      SelectionChanged="LogLevelCombo_SelectionChanged"/>
                        </DockPanel>
                        <TextBlock x:Name="LogsHintText" Foreground="Gray" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        <Button x:Name="OpenLogsButton" HorizontalAlignment="Left" Margin="0,6,0,0" Click="OpenLogsButton_Click"/>
                    </StackPanel>
                </GroupBox>
                <Button x:Name="ResetOnboardingButton" HorizontalAlignment="Left" Margin="0,12,0,0"
                        Click="ResetOnboardingButton_Click"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
