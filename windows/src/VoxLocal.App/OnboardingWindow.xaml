<Window x:Class="VoxLocal.App.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="560" Height="460" ResizeMode="NoResize">
    <DockPanel>
        <Border DockPanel.Dock="Bottom" BorderBrush="#22000000" BorderThickness="0,1,0,0" Padding="16">
            <DockPanel>
                <ProgressBar x:Name="StepProgress" Width="140" Height="8" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BackButton" MinWidth="90" Margin="0,0,8,0" Click="BackButton_Click"/>
                    <Button x:Name="NextButton" MinWidth="90" IsDefault="True" Click="NextButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <TextBlock x:Name="StepGlyph" FontFamily="Segoe Fluent Icons" FontSize="26"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="StepTitle" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel x:Name="StepContent"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
