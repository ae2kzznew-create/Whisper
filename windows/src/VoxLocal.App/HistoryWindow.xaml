<Window x:Class="VoxLocal.App.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="480" Height="580" MinWidth="380" MinHeight="320"
        Background="#FF17151F">
    <DockPanel Margin="16">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button x:Name="ClearButton" DockPanel.Dock="Right" Padding="12,6" Margin="12,0,0,0"
                    VerticalAlignment="Top" Click="OnClearClick"/>
            <TextBlock x:Name="NoteText" Foreground="#8CFFFFFF" FontSize="12" TextWrapping="Wrap"/>
        </DockPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ItemsHost"/>
        </ScrollViewer>
    </DockPanel>
</Window>
