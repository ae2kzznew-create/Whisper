<Window x:Class="VoxLocal.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="332" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowActivated="False" ShowInTaskbar="False" ResizeMode="NoResize">
    <Border CornerRadius="20" BorderThickness="1" Padding="16,13" Margin="14,10,14,18">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F51E1B2C" Offset="0"/>
                <GradientStop Color="#F515121F" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#7AA855F7" Offset="0"/>
                <GradientStop Color="#42EC4899" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Direction="270" Opacity="0.5" Color="#000000"/>
        </Border.Effect>
        <DockPanel>
            <Border x:Name="GlyphChip" DockPanel.Dock="Left" Width="36" Height="36"
                    CornerRadius="18" VerticalAlignment="Center">
                <TextBlock x:Name="StateGlyph" FontFamily="Segoe Fluent Icons" FontSize="16"
                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" FontSize="13.5" FontWeight="SemiBold" Foreground="White"/>
                <UniformGrid x:Name="LevelMeter" Rows="1" Columns="14"
                             Height="14" Margin="0,6,0,2" Visibility="Collapsed"/>
                <TextBlock x:Name="SubtitleText" FontSize="11" Foreground="#8CFFFFFF"
                           TextWrapping="Wrap" MaxHeight="32" Margin="0,3,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
