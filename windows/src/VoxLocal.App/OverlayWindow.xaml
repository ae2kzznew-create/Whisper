<Window x:Class="VoxLocal.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="300" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowActivated="False" ShowInTaskbar="False" ResizeMode="NoResize">
    <Border CornerRadius="16" Background="#E6202020"
            BorderBrush="#14FFFFFF" BorderThickness="1" Padding="16,12">
        <DockPanel>
            <TextBlock x:Name="StateGlyph" DockPanel.Dock="Left"
                       FontFamily="Segoe Fluent Icons" FontSize="18"
                       VerticalAlignment="Center" Width="26" TextAlignment="Center"/>
            <StackPanel Margin="12,0,0,0">
                <TextBlock x:Name="TitleText" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                <UniformGrid x:Name="LevelMeter" Rows="1" Columns="12"
                             Height="10" Margin="0,4,0,0" Visibility="Collapsed"/>
                <TextBlock x:Name="SubtitleText" FontSize="11" Foreground="#99FFFFFF"
                           TextWrapping="Wrap" MaxHeight="32" Visibility="Collapsed"/>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
